# Connection string do Supabase.
# IMPORTANTE: use o SESSION POOLER, nao a conexao "direct".
# A direct (db.<ref>.supabase.co) e IPv6-only e nao conecta na maioria das redes.
# Pegue em: painel > botao "Connect" > aba "Session pooler".
# Formato (note o usuario "postgres.<ref>" e o host "pooler.supabase.com"):
DATABASE_URL="postgresql://postgres.[SEU-PROJETO]:[SUA-SENHA]@aws-1-[REGIAO].pooler.supabase.com:5432/postgres"

# Segredo usado para assinar os tokens JWT
JWT_SECRET="troque-este-segredo"

# Porta da API
PORT=3333
